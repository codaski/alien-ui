{
  "name": "alien-ui",
  "version": "0.1.0",
  "description": "Vue 3 / Nuxt 3 component library — themed, headless-ready, and fully ejectable",
  "author": "Alien UI Contributors",
  "license": "MIT",
  "type": "module",

  "files": ["dist", "src"],

  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types":  "./dist/index.d.ts"
    },
    "./nuxt": {
      "import": "./dist/nuxt.mjs",
      "types":  "./dist/nuxt.d.ts"
    },
    "./styles": "./dist/styles/index.css",
    "./variants": {
      "import": "./dist/variants.mjs",
      "types":  "./dist/variants.d.ts"
    },
    "./components/*": {
      "import": "./dist/components/*.mjs"
    }
  },

  "main":   "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types":  "./dist/index.d.ts",

  "scripts": {
    "dev":           "vite",
    "build":         "vite build && vue-tsc --emitDeclarationOnly",
    "typecheck":     "vue-tsc --noEmit",
    "test":          "vitest run",
    "test:watch":    "vitest",
    "test:ui":       "vitest --ui",
    "lint":          "eslint .",
    "lint:fix":      "eslint . --fix",
    "new:component": "tsx cli/new-component.ts"
  },

  "peerDependencies": {
    "vue": ">=3.5.0"
  },

  "dependencies": {
    "reka-ui":                  "^2.0.0",
    "vee-validate":             "^4.14.0",
    "@vee-validate/zod":        "^4.14.0",
    "zod":                      "^3.23.0",
    "vue-i18n":                 "^9.14.0",
    "class-variance-authority": "^0.7.0",
    "clsx":                     "^2.1.0",
    "tailwind-merge":           "^2.5.0"
  },

  "devDependencies": {
    "vue":                          "^3.5.0",

    "tailwindcss":                  "^4.0.0",
    "@tailwindcss/vite":            "^4.0.0",

    "typescript":                   "^5.4.0",
    "vite":                         "^6.0.0",
    "@vitejs/plugin-vue":           "^5.2.0",
    "vite-plugin-dts":              "^4.3.0",
    "vue-tsc":                      "^2.1.0",

    "vitest":                       "^2.1.0",
    "@vue/test-utils":              "^2.4.0",
    "@testing-library/vue":         "^8.1.0",
    "@testing-library/user-event":  "^14.5.0",
    "happy-dom":                    "^15.7.0",

    "eslint":                       "^9.14.0",
    "@antfu/eslint-config":         "^3.10.0",

    "@nuxt/kit":                    "^3.13.0",
    "nuxt":                         "^3.13.0",

    "tsx":                          "^4.19.0"
  },

  "keywords": [
    "vue", "nuxt", "ui", "components", "tailwind", "reka-ui",
    "design-system", "headless", "accessible", "typescript"
  ],

  "repository": {
    "type": "git",
    "url":  "https://github.com/your-org/alien-ui"
  },

  "bugs": {
    "url": "https://github.com/your-org/alien-ui/issues"
  }
}
