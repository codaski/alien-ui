{
  "name": "alien-ui",
  "version": "0.1.0",
  "description": "Vue 3 / Nuxt component library — themed, headless-ready, and fully ejectable",
  "author": "Alien UI Contributors",
  "license": "MIT",
  "type": "module",

  "files": ["dist", "src"],

  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types":  "./dist/index.d.ts"
    },
    "./nuxt": {
      "import": "./dist/nuxt.mjs",
      "types":  "./dist/nuxt.d.ts"
    },
    "./styles":   "./dist/styles/index.css",
    "./variants": {
      "import": "./dist/variants.mjs",
      "types":  "./dist/variants.d.ts"
    },
    "./components/*": {
      "import": "./dist/components/*.mjs"
    }
  },

  "main":   "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types":  "./dist/index.d.ts",

  "scripts": {
    "dev":           "vite",
    "build":         "vite build && vue-tsc --emitDeclarationOnly",
    "typecheck":     "vue-tsc --noEmit",
    "test":          "vitest run",
    "test:watch":    "vitest",
    "test:ui":       "vitest --ui",
    "lint":          "eslint .",
    "lint:fix":      "eslint . --fix",
    "new:component": "tsx cli/new-component.ts"
  },

  "peerDependencies": {
    "vue": ">=3.5.0"
  },

  "dependencies": {
    "reka-ui":                  "^2.9.7",
    "vee-validate":             "^5.0.0-beta.1",
    "zod":                      "^4.4.3",
    "vue-i18n":                 "^11.4.2",
    "class-variance-authority": "^0.7.1",
    "clsx":                     "^2.1.1",
    "tailwind-merge":           "^3.6.0"
  },

  "devDependencies": {
    "vue":                         "^3.5.34",

    "tailwindcss":                 "^4.3.0",
    "@tailwindcss/vite":           "^4.3.0",

    "typescript":                  "^6.0.3",
    "vite":                        "^8.0.12",
    "@vitejs/plugin-vue":          "^6.0.6",
    "vite-plugin-dts":             "^5.0.0",
    "vue-tsc":                     "^3.2.8",

    "vitest":                      "^4.1.6",
    "@vue/test-utils":             "^2.4.10",
    "@testing-library/vue":        "^8.1.0",
    "@testing-library/user-event": "^14.6.1",
    "happy-dom":                   "^20.9.0",

    "eslint":                      "^10.3.0",
    "@antfu/eslint-config":        "^8.2.0",

    "nuxt":                        "^4.4.5",
    "@nuxt/kit":                   "^4.4.5",

    "tsx":                         "^4.21.0"
  },

  "keywords": [
    "vue", "nuxt", "ui", "components", "tailwind", "reka-ui",
    "design-system", "headless", "accessible", "typescript"
  ],

  "repository": {
    "type": "git",
    "url":  "https://github.com/codaski/alien-ui.git"
  },

  "bugs": {
    "url": "https://github.com/codaski/alien-ui/issues"
  },

  "homepage": "https://github.com/codaski/alien-ui#readme"
}
